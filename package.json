  "resolutions": {
    "@types/node": "^24"
  },
  "packageManager": "pnpm@10.30.2",
  "jscpd": {
    "threshold": 0,
    "reporters": [
      "markdown"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**",
      "**/tests/**",
      "**/.next/**",
      "**/*.json",
      "**/*.tsx",
      "**/*.test.ts",
      "**/*.css",
      "**/*.md"
    ],
